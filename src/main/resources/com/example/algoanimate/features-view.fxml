<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<BorderPane prefHeight="800" prefWidth="1200" styleClass="root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.algoanimate.FeaturesController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="navbar">
            <padding><Insets bottom="15" left="30" right="30" top="15" /></padding>
            <Button onAction="#handleBack" text="← Back" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-background-radius: 25; -fx-cursor: hand;" />
            <Label style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="AlgoAnimate Features Overview" />
            <Region HBox.hgrow="ALWAYS" />
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER">
            <padding><Insets bottom="50" left="40" right="40" top="40" /></padding>

            <FlowPane fx:id="featuresContainer" alignment="TOP_CENTER" hgap="30" vgap="30" />

        </ScrollPane>
    </center>

</BorderPane>