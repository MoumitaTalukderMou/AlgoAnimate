<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.algoanimate.QueueController"
            stylesheets="@style.css" prefWidth="1200" prefHeight="800" styleClass="root">

    <top>
        <HBox spacing="20" alignment="CENTER_LEFT" styleClass="navbar">
            <padding><Insets top="15" right="30" bottom="15" left="30"/></padding>
            <Button onAction="#handleBack" text="← Back" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-background-radius: 25; -fx-cursor: hand;" />
            <Label text="Queue Visualizer" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="FIFO (First In, First Out)" style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 16px;"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="0">
            <VBox HBox.hgrow="ALWAYS" spacing="25" alignment="TOP_CENTER">
                <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

                <HBox spacing="12" alignment="CENTER" styleClass="control-panel-mini">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>

                    <TextField fx:id="inputField" promptText="Enter value..." styleClass="input-field"
                               prefWidth="120" minWidth="120" />

                    <Button text="Enqueue" styleClass="action-btn, btn-enqueue" onAction="#handleEnqueue"
                            prefWidth="105" minWidth="105" />

                    <Button text="Dequeue" styleClass="action-btn, btn-dequeue" onAction="#handleDequeue"
                            prefWidth="105" minWidth="105" />

                    <Button text="Peek Front" styleClass="action-btn, btn-peek" onAction="#handlePeek"
                            prefWidth="115" minWidth="115" />

                    <Button text="Is Empty" styleClass="action-btn, btn-status" onAction="#handleIsEmpty"
                            prefWidth="100" minWidth="100" />

                    <Button text="Is Full" styleClass="action-btn, btn-status" onAction="#handleIsFull"
                            prefWidth="90" minWidth="90" />

                    <Button text="Clear" styleClass="action-btn, btn-clear" onAction="#handleClear"
                            prefWidth="85" minWidth="85" />
                </HBox>

                <VBox alignment="CENTER" VBox.vgrow="ALWAYS" style="-fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 2 0; -fx-padding: 20;">

                    <ScrollPane styleClass="main-scroll-pane" fitToWidth="true" fitToHeight="true"
                                vbarPolicy="NEVER" hbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS"
                                style="-fx-background-color: transparent;">

                        <HBox fx:id="queueContainer" spacing="15" alignment="CENTER_LEFT"
                              style="-fx-border-color: #38bdf8; -fx-border-width: 3 0 3 3; -fx-padding: 20;"
                              prefHeight="150" maxHeight="150" />
                    </ScrollPane>

                </VBox>
            </VBox>

            <VBox styleClass="code-panel" prefWidth="400" spacing="15">
                <padding><Insets top="30" right="20" bottom="20" left="20"/></padding>
                <Label text="OPERATION STEP-TRACE" styleClass="sub-header" style="-fx-text-fill: #38bdf8;"/>
                <ListView fx:id="codeListView" styleClass="code-list" VBox.vgrow="ALWAYS"/>

                <VBox spacing="10" styleClass="var-box">
                    <Label fx:id="lblStatus" text="Status: Waiting for input" styleClass="var-text"/>
                    <Label fx:id="lblFront" text="Front Element: None" styleClass="var-text"/>
                    <Label fx:id="lblRear" text="Rear Element: None" styleClass="var-text"/>
                    <Label fx:id="lblSize" text="Queue Size: 0 / 20" styleClass="var-text"/>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>
