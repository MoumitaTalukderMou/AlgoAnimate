<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.algoanimate.SortingController"
            stylesheets="@style.css" prefWidth="1200" prefHeight="800" styleClass="root">

    <top>
        <HBox spacing="20" alignment="CENTER_LEFT" styleClass="navbar">
            <padding><Insets top="15" right="30" bottom="15" left="30"/></padding>

            <Button onAction="#handleBack" text="← Back"
                    style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-background-radius: 25; -fx-cursor: hand;"/>

            <Label text="Sorting Visualizer" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>

            <ComboBox fx:id="algoComboBox" prefWidth="180" styleClass="custom-combo"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="0">
            <VBox HBox.hgrow="ALWAYS" spacing="25" alignment="TOP_CENTER">
                <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

                <HBox spacing="15" alignment="CENTER">
                    <Button text="Gen Random" styleClass="action-btn, btn-random"
                            onAction="#handleRandomize" prefWidth="135" minWidth="135" />

                    <TextField fx:id="inputField" promptText="50, 10, 30..."
                               styleClass="input-field" prefWidth="120" minWidth="120" />

                    <Button text="Set" styleClass="action-btn, btn-set"
                            onAction="#handleCustomInput" prefWidth="80" minWidth="80" />

                    <Button text="Start" styleClass="action-btn, btn-start"
                            onAction="#handleSort" prefWidth="90" minWidth="90" />

                    <Button fx:id="pauseBtn" text="Pause" styleClass="action-btn, btn-pause"
                            onAction="#handlePause" prefWidth="105" minWidth="105" />

                    <Label text="Speed:" minWidth="65"
                           style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 14px;"/>

                    <Slider fx:id="speedSlider" styleClass="custom-slider"
                            prefWidth="130" min="100" max="1000" value="500"/>
                </HBox>

                <HBox fx:id="displayPane" spacing="10" alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS"
                      style="-fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 0 0 2 0;">
                    <padding>
                        <Insets bottom="20"/>
                    </padding>
                </HBox>
            </VBox>

            <VBox styleClass="code-panel" prefWidth="400" spacing="15">
                <padding><Insets top="30" right="20" bottom="20" left="20"/></padding>

                <Label text="ALGORITHM STEP-TRACE" styleClass="sub-header"
                       style="-fx-text-fill: #38bdf8; -fx-font-weight: bold;"/>

                <ListView fx:id="codeListView" styleClass="code-list" VBox.vgrow="ALWAYS"/>

                <VBox spacing="10" styleClass="var-box"
                      style="-fx-background-color: #1e293b; -fx-padding: 15; -fx-background-radius: 10;">
                    <Label fx:id="lblStatus" text="Status: Waiting"
                           styleClass="var-text" style="-fx-text-fill: #10b981; -fx-font-weight: bold;"/>
                    <Label fx:id="lblComparisons" text="Comparisons: 0"
                           styleClass="var-text" style="-fx-text-fill: white;"/>
                    <Label fx:id="lblSwaps" text="Swaps: 0"
                           styleClass="var-text" style="-fx-text-fill: white;"/>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>