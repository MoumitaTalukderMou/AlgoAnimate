<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.algoanimate.LinkedListController"
            stylesheets="@style.css" prefWidth="1200" prefHeight="800" styleClass="root">

    <top>
        <HBox spacing="20" alignment="CENTER_LEFT" styleClass="navbar">
            <padding><Insets top="15" right="30" bottom="15" left="30"/></padding>
            <Button fx:id="btnBack" onAction="#onBackClick" text="← Back" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 8 20 8 20; -fx-background-radius: 25; -fx-cursor: hand;" />
            <Label text="Linked List Algorithms" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="40" alignment="CENTER">
            <Label text="Select Linked List Type" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>

            <HBox spacing="30" alignment="CENTER">
                <Button fx:id="btnSinglyLinkedList" text="Singly Linked List" onAction="#onSinglyLinkedListClick"
                        style="-fx-background-color: #1e293b; -fx-text-fill: #38bdf8; -fx-font-size: 18px; -fx-font-weight: bold; -fx-border-color: #38bdf8; -fx-border-radius: 10; -fx-background-radius: 10; -fx-cursor: hand;"
                        prefWidth="250" prefHeight="150"/>

                <Button fx:id="btnDoublyLinkedList" text="Doubly Linked List" onAction="#onDoublyLinkedListClick"
                        style="-fx-background-color: #1e293b; -fx-text-fill: #38bdf8; -fx-font-size: 18px; -fx-font-weight: bold; -fx-border-color: #38bdf8; -fx-border-radius: 10; -fx-background-radius: 10; -fx-cursor: hand;"
                        prefWidth="250" prefHeight="150"/>

            </HBox>
        </VBox>
    </center>
</BorderPane>