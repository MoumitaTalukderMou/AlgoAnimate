<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.algoanimate.SinglyLinkedListController"
            stylesheets="@style.css" prefWidth="1200" prefHeight="800" styleClass="root">

    <top>
        <HBox spacing="20" alignment="CENTER_LEFT" styleClass="navbar">
            <padding><Insets top="15" right="30" bottom="15" left="30"/></padding>
            <Button fx:id="btnBack" text="← Back" onAction="#onBackClick" styleClass="nav-link"/>
            <Label text="Singly Linked List Visualizer" styleClass="-fx-text-fill: #e0f2fe; -fx-font-size: 26px; -fx-font-weight: bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Select Operation:" style="-fx-text-fill: #94a3b8; -fx-font-weight: bold;"/>
            <ChoiceBox fx:id="SLLChoiceBox" prefWidth="200" styleClass="combo-box-custom"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="0">
            <VBox HBox.hgrow="ALWAYS" spacing="25" alignment="TOP_CENTER" minWidth="0">
                <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

                <VBox alignment="CENTER" VBox.vgrow="ALWAYS"
                      style="-fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 2 0; -fx-padding: 20;">

                    <ScrollPane fitToWidth="false" fitToHeight="true" vbarPolicy="NEVER" hbarPolicy="AS_NEEDED"
                                style="-fx-background-color: transparent;" styleClass="main-scroll-pane">

                        <AnchorPane fx:id="animationPane" prefHeight="550.0" prefWidth="740.0"
                                    minWidth="740.0" maxWidth="Infinity"/>

                    </ScrollPane>

                </VBox>
            </VBox>

            <VBox styleClass="code-panel" prefWidth="400" spacing="15" minWidth="400" maxWidth="400">
                <padding><Insets top="30" right="20" bottom="20" left="20"/></padding>

                <Label text="ACTION &amp; STEP-TRACE" styleClass="sub-header" style="-fx-text-fill: #38bdf8;"/>
                <ListView fx:id="actionListView" styleClass="code-list" VBox.vgrow="ALWAYS"/>

                <VBox spacing="10" styleClass="var-box">
                    <Label fx:id="lblStatus" text="Status: Waiting for input" styleClass="var-text"/>
                    <Label fx:id="lblSize" text="Current Size: 0" styleClass="var-text"/>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>