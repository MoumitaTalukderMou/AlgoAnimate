<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.TextFlow?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.algoanimate.LoginController"
      stylesheets="@style.css"
      prefWidth="1200" prefHeight="800" styleClass="dark-split-root">

    <VBox styleClass="login-left-pane-dark" HBox.hgrow="ALWAYS">

        <VBox alignment="CENTER" spacing="20" VBox.vgrow="ALWAYS">
            <padding>
                <Insets left="60" right="60"/>
            </padding>

            <StackPane>
                <Circle radius="30" fill="transparent" stroke="#38bdf8" strokeWidth="3"
                        style="-fx-effect: dropshadow(gaussian, #38bdf8, 20, 0.5, 0, 0);"/>

                <HBox alignment="CENTER" spacing="5">
                    <HBox alignment="CENTER" spacing="0">
                        <Label text="A" style="-fx-font-size: 20px; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Label text="A" style="-fx-font-size: 20px; -fx-text-fill: #38bdf8; -fx-font-weight: bold;"/>
                    </HBox>
                    <Label text="▶" style="-fx-font-size: 26px; -fx-text-fill: white; -fx-effect: dropshadow(gaussian, white, 10, 0.5, 0, 0); -fx-translate-y: 2;"/>
                </HBox>
            </StackPane>

            <Label text="Visualize with" styleClass="hero-text-small-dark" />

            <TextFlow textAlignment="CENTER">
                <Text text="Algo" styleClass="hero-text-large-dark" />
                <Text text="Animate" styleClass="hero-text-large-accent" />
            </TextFlow>

            <Label text="Visualize complex data structures and algorithms in real-time. Designed for CSE students to master coding with interactive animations."
                   wrapText="true" textAlignment="CENTER" styleClass="hero-description-dark" maxWidth="450" />
        </VBox>

        <VBox alignment="BOTTOM_CENTER">
            <padding>
                <Insets bottom="30"/>
            </padding>

        </VBox>
    </VBox>

    <VBox styleClass="login-right-pane-dark" minWidth="550" alignment="CENTER" spacing="35">
        <padding>
            <Insets left="80" right="80"/>
        </padding>

        <VBox spacing="10" alignment="CENTER_LEFT" maxWidth="380">
            <Label text="Welcome!" styleClass="form-title-dark" />
            <Label text="Please enter your credentials to access your workspace." wrapText="true" styleClass="form-subtitle-dark" />

            <VBox spacing="20" style="-fx-padding: 20 0 0 0;">

                <VBox spacing="8">
                    <Label text="Username" styleClass="input-label-light" />
                    <TextField fx:id="usernameField" promptText="Enter username" styleClass="dark-modern-input" />
                </VBox>

                <VBox spacing="8">
                    <Label text="Password" styleClass="input-label-light" />
                    <PasswordField fx:id="passwordField" promptText="Enter password" styleClass="dark-modern-input" />
                </VBox>
            </VBox>

            <Label fx:id="errorLabel" text="" visible="false"  style="-fx-text-fill: #ef4444; -fx-padding: 10 0 0 0;" />

            <Button fx:id="loginButton" text="Login" onAction="#handleLogin"
                    styleClass="login-btn-cyan" maxWidth="Infinity" />

            <HBox alignment="CENTER" spacing="5" style="-fx-padding: 20 0 0 0;">
                <Label text="Don't have an account?" style="-fx-text-fill: #64748b; -fx-font-size: 13px;" />
                <Hyperlink text="Register" onAction="#handleRegister" style="-fx-text-fill: #38bdf8; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 0;"/>
            </HBox>
        </VBox>
    </VBox>

</HBox>