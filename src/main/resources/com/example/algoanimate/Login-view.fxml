<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.TextFlow?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.algoanimate.LoginController"
            stylesheets="@style.css"
            prefWidth="1200" prefHeight="800">

    <!-- TOP NAVBAR (same as hello-view) -->
    <top>
        <VBox alignment="CENTER" style="-fx-background-color: transparent;">
            <padding>
                <Insets top="20" right="20" bottom="10" left="20"/>
            </padding>

            <HBox styleClass="floating-navbar" alignment="CENTER_LEFT" spacing="10">
                <padding>
                    <Insets top="10" right="20" bottom="10" left="30"/>
                </padding>

                <TextFlow styleClass="logo-flow">
                    <Text text="Algo" styleClass="logo-text-primary"/>
                    <Text text="Animate" styleClass="logo-text-accent"/>
                </TextFlow>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox alignment="CENTER" spacing="25" styleClass="nav-links-container">
                    <Button text="" styleClass="nav-link"/>
                    <Button text="" styleClass="nav-link"/>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER LOGIN CARD -->
    <center>
        <VBox alignment="CENTER" spacing="0">

            <!-- Login Card -->
            <VBox alignment="CENTER" spacing="12"
                  styleClass="login-card"
                  style="-fx-background-color: white;
                         -fx-background-radius: 12;
                         -fx-padding: 32 40 32 40;
                         -fx-min-width: 360;
                         -fx-max-width: 360;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 16, 0, 0, 4);">

                <!-- Title -->
                <Label text="Welcome Back"
                       style="-fx-font-size: 22px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #1e293b;" />

                <Label text="Sign in to your AlgoAnimate account"
                       style="-fx-font-size: 13px;
                              -fx-text-fill: #64748b;" />

                <VBox spacing="4" style="-fx-padding: 12 0 0 0;">

                    <!-- Username -->
                    <Label text="Username"
                           style="-fx-font-size: 13px;
                                  -fx-text-fill: #475569;" />
                    <TextField fx:id="usernameField"
                               promptText="Enter username"
                               style="-fx-pref-height: 40px;
                                      -fx-background-radius: 8;
                                      -fx-border-radius: 8;
                                      -fx-border-color: #cbd5e1;
                                      -fx-border-width: 1;
                                      -fx-font-size: 14px;
                                      -fx-padding: 0 12 0 12;" />

                    <!-- Password -->
                    <Label text="Password"
                           style="-fx-font-size: 13px;
                                  -fx-text-fill: #475569;
                                  -fx-padding: 8 0 0 0;" />
                    <PasswordField fx:id="passwordField"
                                   promptText="Enter password"
                                   style="-fx-pref-height: 40px;
                                          -fx-background-radius: 8;
                                          -fx-border-radius: 8;
                                          -fx-border-color: #cbd5e1;
                                          -fx-border-width: 1;
                                          -fx-font-size: 14px;
                                          -fx-padding: 0 12 0 12;" />
                </VBox>

                <!-- Error label -->
                <Label fx:id="errorLabel"
                       text=""
                       visible="false"
                       style="-fx-text-fill: #ef4444;
                              -fx-font-size: 12px;" />

                <!-- Login Button -->
                <Button fx:id="loginButton"
                        text="Login"
                        onAction="#handleLogin"
                        style="-fx-background-color: #3b82f6;
                               -fx-text-fill: white;
                               -fx-font-size: 14px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-pref-height: 42px;
                               -fx-cursor: hand;"
                        maxWidth="Infinity" />

                <!-- Register link -->
                <HBox alignment="CENTER" spacing="4">
                    <Label text="Don't have an account?"
                           style="-fx-font-size: 12px;
                                  -fx-text-fill: #64748b;" />
                    <Hyperlink text="Register"
                               onAction="#handleRegister"
                               style="-fx-font-size: 12px;" />
                </HBox>

            </VBox>
        </VBox>
    </center>

</BorderPane>